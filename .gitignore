venv/
.env
__pycache__/
*.pyc
*.log
progress*.json
.DS_Store

# interfacile keeps everything in .interfacile/ — config.json is committed,
# the runtime state it writes (pins, scratchpad, to-do) is not.
**/.interfacile/*
!**/.interfacile/config.json
# legacy flat locations, before the .interfacile/ folder
.ticket-pins.json
.scratchpad.md
.todo.md
# hygiene engine state
.ticket_hygiene_last_run
.ticket_hygiene_baseline.json

# Python packaging metadata (generated by pip install -e)
*.egg-info/
