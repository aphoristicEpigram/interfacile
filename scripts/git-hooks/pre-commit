#!/bin/bash
# Pre-commit hook: ticket hygiene + source-pattern gates
# Install: cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# Runs the ticket scanner on staged files. Blocking.

set -euo pipefail

PYTHON="venv/bin/python"
if [ ! -f "$PYTHON" ]; then
    echo "WARNING: venv/bin/python not found. Skipping pre-commit checks."
    exit 0
fi

echo "=== Pre-commit: Ticket Hygiene ==="
$PYTHON scripts/ticket_hygiene/audit_tickets.py

echo "=== Pre-commit: Ruff ==="
RUFF="venv/bin/ruff"
if [ -f "$RUFF" ]; then
    $RUFF check clean_paste_lite tests scripts
else
    echo "WARNING: venv/bin/ruff not found. Skipping ruff."
fi

echo "=== Pre-commit: Engine.default() Singleton Comments ==="
$PYTHON scripts/ci/check_engine_default_singleton.py

echo "=== Pre-commit: HMAC digestmod string literal check ==="
$PYTHON scripts/ci/check_hmac_digestmod.py

echo "=== Pre-commit: Test Quality Gates ==="
$PYTHON scripts/ci/pre_commit_quality_gates.py

echo "=== Pre-commit: Test Quality Lint ==="
$PYTHON scripts/ci/test_quality_lint.py

echo "=== Pre-commit: op.op pattern check ==="
$PYTHON scripts/ci/check_op_op_pattern.py

echo "=== Pre-commit: Marker Sanity ==="
$PYTHON scripts/ci/check_marker_sanity.py

echo "=== Pre-commit: Strict Candidate Limit Opt-outs ==="
$PYTHON scripts/ci/check_strict_candidate_limit.py

echo "=== Pre-commit: Docs Freshness ==="
$PYTHON scripts/ci/check_docs_freshness.py

echo "=== Pre-commit: Doc Link Check ==="
$PYTHON scripts/ci/check_doc_links.py

echo "=== Pre-commit: Mermaid Diagrams (staged only) ==="
MERMAID_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' \
    | while read -r f; do [ -f "$f" ] && grep -qE '```mermaid' "$f" && echo "$f"; done || true)
if [ -n "$MERMAID_FILES" ]; then
    $PYTHON scripts/dev/check_mermaid.py $MERMAID_FILES
else
    echo "  no staged diagrams — skipped"
fi
