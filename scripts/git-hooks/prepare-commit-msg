#!/bin/bash
# prepare-commit-msg hook: auto-inject ceremony template when closing tickets
# Install: cp scripts/git-hooks/prepare-commit-msg .git/hooks/prepare-commit-msg && chmod +x .git/hooks/prepare-commit-msg
#
# Runs after the default commit message is prepared but before the editor opens.
# Only injects the ceremony template when a ticket is actually being closed:
#   - a file is renamed/moved from open/ to closed/ (same basename), OR
#   - a file is deleted from open/ and added to closed/, OR
#   - a closed/ file is modified to add status: CLOSED.
# Idempotent: does nothing if the message already contains "Ceremony:".

set -euo pipefail

COMMIT_MSG_FILE="$1"

# Idempotent: don't inject if template is already present
if grep -q "Ceremony:" "$COMMIT_MSG_FILE" 2>/dev/null; then
    exit 0
fi

# Get staged diff with status
STAGED_DIFF=$(git diff --cached --name-status)

IS_CLOSING=false

# 1. Detect renames from open/ to closed/ with matching basenames
while IFS=$'\t' read -r status src dst; do
    if [[ "$status" == R* ]]; then
        if [[ "$src" == */open/*.md && "$dst" == */closed/*.md ]]; then
            src_base=$(basename "$src")
            dst_base=$(basename "$dst")
            if [ "$src_base" = "$dst_base" ]; then
                IS_CLOSING=true
                break
            fi
        fi
    fi
done <<< "$STAGED_DIFF"

# 2. Detect delete-from-open + add-to-closed with matching basenames
if [ "$IS_CLOSING" != "true" ]; then
    OPEN_DELETED=$(echo "$STAGED_DIFF" | awk -F'\t' '$1 == "D" && $2 ~ /\/open\/.*\.md$/ { print $2 }' | while read -r f; do basename "$f"; done | sort -u)
    CLOSED_ADDED=$(echo "$STAGED_DIFF" | awk -F'\t' '$1 == "A" && $2 ~ /\/closed\/.*\.md$/ { print $2 }' | while read -r f; do basename "$f"; done | sort -u)
    if [ -n "$OPEN_DELETED" ] && [ -n "$CLOSED_ADDED" ]; then
        MATCHES=$(comm -12 <(echo "$OPEN_DELETED") <(echo "$CLOSED_ADDED"))
        if [ -n "$MATCHES" ]; then
            IS_CLOSING=true
        fi
    fi
fi

# 3. Detect closed/ file gaining status: CLOSED
if [ "$IS_CLOSING" != "true" ]; then
    CLOSED_MODIFIED=$(echo "$STAGED_DIFF" | awk -F'\t' '$1 == "M" && $2 ~ /\/closed\/.*\.md$/ { print $2 }')
    if [ -n "$CLOSED_MODIFIED" ]; then
        for f in $CLOSED_MODIFIED; do
            if git diff --cached --unified=0 -- "$f" 2>/dev/null | grep -qE '^\+status:\s*CLOSED'; then
                IS_CLOSING=true
                break
            fi
        done
    fi
fi

if [ "$IS_CLOSING" != "true" ]; then
    exit 0
fi

# Append ceremony template
cat >> "$COMMIT_MSG_FILE" <<'EOF'

Ceremony:

Approved:

If I Had 3 More Hours:
EOF
